Cache With Time Limit



class TimeLimitedCache {
    constructor() {
        this.cache = new Map();
    }
    
    set(key, value, duration) {
        const now = Date.now();
        const exists = this.cache.has(key) && this.cache.get(key).expiry > now;
        
        // Store with expiry time
        this.cache.set(key, {
            value: value,
            expiry: now + duration
        });
        
        // Set timeout to clean up expired key
        setTimeout(() => {
            if (this.cache.has(key) && this.cache.get(key).expiry <= Date.now()) {
                this.cache.delete(key);
            }
        }, duration);
        
        return exists;
    }
    
    get(key) {
        const now = Date.now();
        const entry = this.cache.get(key);
        
        if (entry && entry.expiry > now) {
            return entry.value;
        }
        return -1;
    }
    
    count() {
        const now = Date.now();
        let count = 0;
        
        for (const [key, entry] of this.cache) {
            if (entry.expiry > now) {
                count++;
            }
        }
        return count;
    }
}
