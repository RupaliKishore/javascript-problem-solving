Array Reduce Transformation


/**
 * @param {number[]} arr
 * @param {Function} fn
 * @param {number} init
 * @return {number}
 */
var reduce = function(arr, fn, init) {
    let accumulator = init;
    for (let i = 0; i < arr.length; i++) {
        accumulator = fn(accumulator, arr[i]);
    }
    return accumulator;
};
