Flatten Deeply Nested Array


/**
 * @param {Array} arr
 * @param {number} depth
 * @return {Array}
 */
var flat = function(arr, depth = 1) {
    const result = [];
    
    for (const item of arr) {
        if (Array.isArray(item) && depth > 0) {
            // Recursively flatten nested array with depth-1
            result.push(...flat(item, depth - 1));
        } else {
            result.push(item);
        }
    }
    
    return result;
};
